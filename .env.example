# ============================================
# n8n Animated Story Workflow - Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys.
# Only GEMINI_API_KEY is recommended — everything else is optional.

# --- LLM API Keys (for script generation) ---
# Get free Gemini key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get free Groq key: https://console.groq.com/keys
GROQ_API_KEY=

# --- Image API Keys (for future nodes) ---
# Get free Pexels key: https://www.pexels.com/api/new/
PEXELS_API_KEY=
